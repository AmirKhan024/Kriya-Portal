# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth secrets — generate 32-char hex for production
ACCESS_TOKEN_SECRET=dev_access_secret_change_in_production_32chars
REFRESH_TOKEN_SECRET=dev_refresh_secret_change_in_production_32chars
INVITE_TOKEN_SECRET=dev_invite_secret_change_in_production_32chars

# Token TTLs (seconds)
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
INVITE_TOKEN_TTL_SECONDS=259200

# Database
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Groq (LLM API) — required for Phase 1d prescription CDE pipeline
# Get a free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Nudges (feature 2c) — messaging dispatch. PLACEHOLDERS: while unset, the dispatcher
# in src/modules/nudges/dispatch.ts returns a stub id and makes NO outbound call.
GUPSHUP_API_KEY=          # WhatsApp (approved templates)
GUPSHUP_SOURCE=           # registered WhatsApp sender number
EXPO_ACCESS_TOKEN=        # app push (Expo → FCM/APNs)
SMS_PROVIDER_KEY=         # SMS fallback (MSG91 / Twilio)
N8N_WEBHOOK_SECRET=       # shared secret for the N8N inactivity-watcher cron

# Care Video (feature 3a) — Mux. PLACEHOLDERS: while unset, src/modules/videos/mux.ts
# returns an instant-ready stub asset and accepts unsigned webhooks.
MUX_TOKEN_ID=             # Mux API access token id
MUX_TOKEN_SECRET=         # Mux API secret
MUX_WEBHOOK_SECRET=       # Mux webhook signing secret (HMAC verification)
