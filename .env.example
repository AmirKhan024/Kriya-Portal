# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth secrets — generate 32-char hex for production
ACCESS_TOKEN_SECRET=dev_access_secret_change_in_production_32chars
REFRESH_TOKEN_SECRET=dev_refresh_secret_change_in_production_32chars
INVITE_TOKEN_SECRET=dev_invite_secret_change_in_production_32chars

# Token TTLs (seconds)
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
INVITE_TOKEN_TTL_SECONDS=259200

# Database
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Anthropic (Claude API) — required for Phase 1d prescription CDE pipeline
ANTHROPIC_API_KEY=your_anthropic_api_key_here
